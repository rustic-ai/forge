{
  "name": "@rustic-ai/api-client",
  "version": "0.0.9",
  "description": "TypeScript client for the Rustic AI Forge HTTP API, generated from its OpenAPI specification.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rustic-ai/forge.git",
    "directory": "clients/typescript"
  },
  "homepage": "https://github.com/rustic-ai/forge/tree/main/clients/typescript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "openapi-generator-cli generate",
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.13.0",
    "typescript": "^5.4.0"
  }
}
